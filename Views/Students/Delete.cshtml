@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="page-header">
    <h1>🗑️ Delete Student</h1>
    <a asp-action="Index" class="btn btn-outline">← Back to List</a>
</div>

<div class="detail-card danger-card">
    <div class="warning-banner">
        ⚠️ Are you sure you want to delete this student record? This action cannot be undone.
    </div>

    <div class="detail-grid">
        <div class="detail-item">
            <label>Full Name</label>
            <span><strong>@Model.FullName</strong></span>
        </div>
        <div class="detail-item">
            <label>Email</label>
            <span>@Model.Email</span>
        </div>
        <div class="detail-item">
            <label>Course</label>
            <span>@Model.Course</span>
        </div>
        <div class="detail-item">
            <label>Enrolled On</label>
            <span>@Model.EnrollmentDate.ToString("dd MMM yyyy")</span>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">🗑️ Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
